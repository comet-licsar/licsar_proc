#!/bin/bash
#this script will download a given file (zip file) from alaska facility

if [ -f ~/.asf_credentials ]; then
 export WGETRC=~/.asf_credentials
else
 export WGETRC=$LiCSAR_configpath/alaska_credentials_wget
fi

if [ -z $1 ]; then echo "Parameter is the full URL"; exit; fi
if [ `echo $1 | grep -c https` -eq 0 ]; then echo "Parameter is the file URL"; exit; fi
URL=$1

wget -c --no-check-certificate --no-hsts $URL
